{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "ignoreDeprecations": "6.0",
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "js/*": ["themes/hugo-theme-bootstrap/assets/js/*"],
      "@params": ["types/hugo-params"]
    },
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true
  },
  "include": [
    "types/**/*.d.ts",
    "themes/hugo-theme-bootstrap/assets/js/**/*.ts",
    "assets/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "public",
    "resources"
  ]
}
